  { id: "1", name: "Ananya Sharma", email: "ananya@techcorp.in", phone: "9876543210", company: "TechCorp India", status: "Qualified", notes: "Interested in enterprise plan. Follow up next week.", createdAt: "2025-11-01T09:00:00Z" },
  { id: "2", name: "Rohan Mehta", email: "rohan@startuphub.io", phone: "9123456789", company: "StartupHub", status: "Contacted", notes: "Demo scheduled for Friday.", createdAt: "2025-11-15T11:30:00Z" },
  { id: "3", name: "Priya Nair", email: "priya@designstudio.co", phone: "8899001122", company: "Design Studio", status: "New", notes: "Came through LinkedIn campaign.", createdAt: "2025-12-01T08:00:00Z" },
  { id: "4", name: "Vikram Singh", email: "vikram@logisticspro.com", phone: "7766554433", company: "LogisticsPro", status: "Converted", notes: "Closed deal. Onboarding in progress.", createdAt: "2025-10-10T14:00:00Z" },
  { id: "5", name: "Sneha Banerjee", email: "sneha@retailmart.in", phone: "9988776655", company: "RetailMart", status: "Lost", notes: "Went with competitor. Budget constraints.", createdAt: "2025-09-20T10:00:00Z" },
  { id: "6", name: "Aditya Kumar", email: "aditya@fintech.in", phone: "9012345678", company: "FinTech Solutions", status: "New", notes: "Referral from Vikram Singh.", createdAt: "2026-01-05T09:00:00Z" },
